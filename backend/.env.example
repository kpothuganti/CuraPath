# Server
PORT=3000
NODE_ENV=development

# Auth (AWS Cognito or custom JWT secret for local dev)
JWT_SECRET=change-me-in-production-use-secrets-manager
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=30d

# Anthropic
# Set USE_MOCK_CLAUDE=true to skip real API calls during development (no key needed)
USE_MOCK_CLAUDE=true
ANTHROPIC_API_KEY=sk-ant-...

# Database (RDS PostgreSQL in prod, local postgres for dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=discharge
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# AWS (production)
AWS_REGION=us-east-1
S3_BUCKET=discharge-raw-inputs

# CORS
ALLOWED_ORIGINS=http://localhost:8081
