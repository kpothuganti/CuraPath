{
  "expo": {
    "name": "CuraPath",
    "slug": "recharge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#13131a"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4f7eff",
          "sounds": []
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kspothuganti.recharge",
      "entitlements": {
        "com.apple.developer.usernotifications.time-sensitive": true
      },
      "infoPlist": {
        "NSCameraUsageDescription": "ReCharge uses your camera to scan hospital discharge paperwork.",
        "NSPhotoLibraryUsageDescription": "ReCharge accesses your photo library to upload a photo of your discharge paperwork.",
        "NSUserNotificationsUsageDescription": "ReCharge sends medication reminders and daily check-in alerts to keep your recovery on track."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kspothuganti.recharge"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
